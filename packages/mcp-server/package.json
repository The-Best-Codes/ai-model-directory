{
  "name": "ai-model-directory-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for querying the AI Model Directory",
  "private": true,
  "type": "module",
  "bin": {
    "ai-model-directory-mcp-server": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "start:http": "TRANSPORT=http bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.1.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/express": "^5.0.0",
    "typescript": "^6.0.3"
  }
}
